{
  "name": "canyonworks",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "wasm:build": "wasm-pack build wasm --target web --release && node -e \"require('fs').rmSync('wasm/pkg/.gitignore',{force:true})\"",
    "wasm:dev": "wasm-pack build wasm --target web --dev && node -e \"require('fs').rmSync('wasm/pkg/.gitignore',{force:true})\""
  },
  "dependencies": {
    "lil-gui": "^0.20.0",
    "simplex-noise": "^4.0.3",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@types/three": "^0.180.0",
    "sharp": "^0.35.3",
    "typescript": "~5.7.0",
    "vite": "^6.0.0"
  }
}
